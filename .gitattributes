# ============================================================
# TripCart .gitattributes
# 모든 텍스트 파일은 LF로 통일 (cross-platform 협업 대비)
# ============================================================

# 기본: 텍스트 파일은 LF
* text=auto eol=lf

# 명시적 텍스트 파일
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.sql   text eol=lf
*.py    text eol=lf
*.sh    text eol=lf
*.env*  text eol=lf

# 바이너리 — 변환 안 함
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.apk   binary
*.ipa   binary
