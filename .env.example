# ============================================================
# TripCart 환경 변수 템플릿
# 이 파일을 복사해 .env.local 로 사용하세요.
# .env.local 은 절대 커밋하지 않습니다.
# ============================================================

# ── Supabase (public — 클라이언트 안전) ─────────────────────
# web: NEXT_PUBLIC_ 접두어로 브라우저에 노출됨
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase (server only — 절대 클라이언트에 노출 금지) ─────
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Optimizer 내부 토큰 ──────────────────────────────────────
# FastAPI optimizer 서비스와 Next.js 서버 간 통신용
OPTIMIZER_INTERNAL_TOKEN=

# ── 외부 API ─────────────────────────────────────────────────
TMAP_API_KEY=
NAVER_MAP_CLIENT_ID=
OCR_PROVIDER_KEY=

# ── Optimizer 서비스 URL (server only) ───────────────────────
OPTIMIZER_BASE_URL=http://localhost:8000
