# ============================================================
# TripCart .gitignore
# ============================================================

# Node / pnpm
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Next.js
.next/
out/
build/
dist/

# Turbo
.turbo/

# Expo / React Native
apps/mobile/.expo/
apps/mobile/dist/
apps/mobile/ios/
apps/mobile/android/
*.apk
*.aab
*.ipa
*.xcworkspace
*.xcodeproj
Pods/

# Python / optimizer
services/optimizer/.venv/
services/optimizer/__pycache__/
services/optimizer/**/__pycache__/
services/optimizer/**/*.pyc
services/optimizer/**/*.pyo
services/optimizer/.python-version
*.egg-info/
dist/
.uv/

# Environment variables
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
# .env.example is allowed when it contains placeholders only.

# Supabase local state
infra/supabase/.branches/
infra/supabase/.temp/
supabase/.branches/
supabase/.temp/

# OS / Editor
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/settings.json
.idea/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test output and caches
coverage/
.vitest/
playwright-report/
test-results/

# OMX / RALPH local state
.omc/
.omx/

# Miscellaneous
*.tsbuildinfo

.gstack/
infra/supabase/supabase/

# Playwright CLI output (generated, not versioned)
.playwright-cli/

# Playwright test output (screenshots/videos, can be large)
output/

# Temporary design export folders (Figma/AI tool output, not versioned)
tripcart_mobile_design/
tripcart_web_desgin/
